# Required: gRPC server to forward decrypted connections to
UPSTREAM=ams.konstruct.cc:443

# Optional: host port to bind (default: 443)
LISTEN_PORT=443

# Optional: where to forward TLS/HTTP probes for active-probing resistance.
# Use a real HTTPS site so the server looks legitimate when probed.
COVER_SITE=cloudflare.com:443
