# Required: gRPC server to forward decrypted connections to
UPSTREAM=ams.konstruct.cc:443

# Host port to bind (default: 9894).
# Avoid 443 and 9443 — they are on DPI watch-lists in Russia.
# Any non-standard port works fine with obfs4 (traffic looks like random bytes).
LISTEN_PORT=9894

# TLS SNI hostname to impersonate.
# Pick a domain plausible for the VPS host's network range:
#   Hetzner DE/FI →  fra1.digitaloceanspaces.com  or  storage.bunnycdn.com
#   DigitalOcean  →  fra1.digitaloceanspaces.com
#   OVH/Scaleway  →  storage.sbg.cloud.ovh.net
# The relay generates a self-signed cert matching this domain.
# iOS app pins the SPKI fingerprint — CA is never checked.
TLS_SNI_HOST=fra1.digitaloceanspaces.com

# WebTunnel: leave empty on new relays without CDN fronting.
# WebTunnel over a bare IP triggers DPI active probing and gets the IP blocked.
# Enable only after placing Cloudflare (or equivalent CDN) in front of the relay.
WT_PATH=

# Optional: directory for persistent state (obfs4 identity + TLS cert)
STATE_DIR=/data

# Optional: log verbosity
RUST_LOG=info
