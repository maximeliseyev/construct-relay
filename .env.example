# Required: gRPC server to forward decrypted connections to
UPSTREAM=ams.konstruct.cc:443

# Optional: host port to bind (default: 443)
LISTEN_PORT=443

# Optional: directory for persistent state (obfs4 identity + TLS cert)
# Files created: relay.obfs4, relay.crt, relay.key
# Map this to a Docker volume so keys survive container restarts.
STATE_DIR=/data

# Optional: TLS SNI hostname to impersonate (default: storage.yandexcloud.net)
# The relay generates a self-signed cert for this hostname.
# iOS app must pin the SPKI fingerprint printed at startup.
TLS_SNI_HOST=storage.yandexcloud.net
